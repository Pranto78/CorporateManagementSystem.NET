@model List<CorporateTaskManagementSystem.Entities.Models.TaskAssignment>

@{
    ViewBag.Title = "Deleted Tasks";
}

<style>
    body {
        background: #f4f1ec;
    }

    .classic-page {
        padding: 30px 0;
    }

    .classic-header {
        background: #ffffff;
        border-left: 8px solid #8b5e34;
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 24px;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

        .classic-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
            color: #2f241d;
            margin: 0;
        }

        .classic-header p {
            color: #6b5b4f;
            margin: 6px 0 0;
            font-size: 15px;
        }

    .classic-header-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .classic-btn {
        border-radius: 8px;
        padding: 10px 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: 0.2s ease;
        border: none;
    }

        .classic-btn:hover {
            text-decoration: none;
            transform: translateY(-2px);
        }

    .btn-dashboard {
        background: #2f241d;
        color: white;
    }

        .btn-dashboard:hover {
            background: #1f1813;
            color: white;
        }

    .btn-active {
        background: #2b7a78;
        color: white;
    }

        .btn-active:hover {
            background: #22615f;
            color: white;
        }

    .classic-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e3d7c8;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        overflow: hidden;
    }

    .classic-card-top {
        background: #3b2f2f;
        color: white;
        padding: 18px 24px;
        border-bottom: 4px solid #8b5e34;
    }

        .classic-card-top h4 {
            margin: 0;
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
        }

    .classic-card-body {
        padding: 24px;
    }

    .classic-note {
        background: #fbf7f1;
        border-left: 5px solid #9b2f2f;
        color: #5f4b3b;
        padding: 13px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .classic-table {
        margin-bottom: 0;
        border: 1px solid #e3d7c8;
    }

        .classic-table thead th {
            background: #2f241d;
            color: white;
            border-color: #4c3a2f;
            font-weight: 700;
            white-space: nowrap;
            vertical-align: middle;
        }

        .classic-table tbody td {
            vertical-align: middle;
            border-color: #eadfd1;
            color: #2f241d;
        }

        .classic-table tbody tr:nth-child(even) {
            background: #fbf7f1;
        }

        .classic-table tbody tr:hover {
            background: #f1e7db;
        }

    .classic-title {
        font-weight: 700;
        color: #2f241d;
    }

    .classic-badge {
        border-radius: 30px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
        display: inline-block;
    }

    .badge-priority {
        background: #fff7e8;
        color: #b9852c;
        border: 1px solid #efd29d;
    }

    .badge-status {
        background: #fff1f1;
        color: #9b2f2f;
        border: 1px solid #f0bcbc;
    }

    .classic-delete-btn {
        background: #9b2f2f;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 8px 13px;
        font-weight: 600;
        transition: 0.2s ease;
    }

        .classic-delete-btn:hover {
            background: #7e2424;
            color: white;
            transform: translateY(-2px);
        }

    .classic-empty {
        background: #fbf7f1;
        border-left: 5px solid #2b7a78;
        color: #5f4b3b;
        padding: 18px;
        border-radius: 10px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .classic-header {
            align-items: flex-start;
        }

            .classic-header h2 {
                font-size: 28px;
            }

        .classic-card-body {
            padding: 16px;
        }
    }
</style>

<div class="container classic-page">

    <div class="classic-header">
        <div>
            <h2>Deleted Task Archive</h2>
            @*<p>Review deleted tasks and permanently remove records when needed.</p>*@
        </div>

        <div class="classic-header-actions">
            <a href="@Url.Action("Index", "Admin")" class="classic-btn btn-dashboard">
                Back to Dashboard
            </a>

            <a href="@Url.Action("Tasks", "Admin")" class="classic-btn btn-active">
                Active Tasks
            </a>
        </div>
    </div>

    <div class="classic-card">

        <div class="classic-card-top">
            <h4>Deleted Tasks</h4>
        </div>

        <div class="classic-card-body">

            @*<div class="classic-note">
                These tasks are soft deleted. Use permanent delete only when you want to remove the task from the database completely.
            </div>*@

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table classic-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Created By</th>
                                <th>Assigned To</th>
                                <th>Assigned By</th>
                                <th>Priority</th>
                                <th>Last Status</th>
                                <th>Deleted At</th>
                                <th>Deleted By</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="classic-title">@item.TaskItem.Title</span>
                                    </td>

                                    <td>
                                        @(item.TaskItem.CreatedByUser != null
                                            ? item.TaskItem.CreatedByUser.FullName
                                            : "N/A")
                                    </td>

                                    <td>
                                        @(item.AssignedToUser != null
                                            ? item.AssignedToUser.FullName
                                            : "N/A")
                                    </td>

                                    <td>
                                        @(item.AssignedByUser != null
                                            ? item.AssignedByUser.FullName
                                            : "N/A")
                                    </td>

                                    <td>
                                        <span class="classic-badge badge-priority">
                                            @item.TaskItem.Priority
                                        </span>
                                    </td>

                                    <td>
                                        <span class="classic-badge badge-status">
                                            @item.TaskItem.Status
                                        </span>
                                    </td>

                                    <td>
                                        @(item.TaskItem.DeletedAt.HasValue
                                            ? item.TaskItem.DeletedAt.Value.ToString("dd MMM yyyy hh:mm tt")
                                            : "-")
                                    </td>

                                    <td>
                                        @(item.TaskItem.DeletedByUser != null
                                            ? item.TaskItem.DeletedByUser.FullName
                                            : "-")
                                    </td>

                                    <td>
                                        @using (Html.BeginForm("PermanentlyDeleteTask", "Admin", new { id = item.TaskAssignmentId }, FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="classic-delete-btn"
                                                    onclick="return confirm('Are you sure? This task will be permanently deleted and cannot be restored.');">
                                                Delete Permanently
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="classic-empty">
                    No deleted tasks found.
                </div>
            }

        </div>
    </div>

</div>