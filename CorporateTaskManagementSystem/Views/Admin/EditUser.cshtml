@model CorporateTaskManagementSystem.Web.ViewModels.UserEditViewModel

@{
    ViewBag.Title = "Edit User";
}

<style>
    body {
        background: #f4f1ec;
    }

    .classic-page {
        padding: 30px 0;
    }

    .classic-header {
        background: #ffffff;
        border-left: 8px solid #8b5e34;
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 24px;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
    }

        .classic-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
            color: #2f241d;
            margin: 0;
        }

        .classic-header p {
            color: #6b5b4f;
            margin: 6px 0 0;
            font-size: 15px;
        }

    .classic-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e3d7c8;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        overflow: hidden;
        max-width: 760px;
        margin: 0 auto;
    }

    .classic-card-top {
        background: #3b2f2f;
        color: white;
        padding: 18px 24px;
        border-bottom: 4px solid #8b5e34;
    }

        .classic-card-top h4 {
            margin: 0;
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
        }

    .classic-card-body {
        padding: 28px;
    }

    .classic-note {
        background: #fbf7f1;
        border-left: 5px solid #b9852c;
        color: #5f4b3b;
        padding: 13px 16px;
        border-radius: 8px;
        margin-bottom: 22px;
        font-weight: 500;
    }

    .classic-form-group {
        margin-bottom: 20px;
    }

        .classic-form-group label {
            font-weight: 700;
            color: #3b2f2f;
            margin-bottom: 7px;
        }

    .classic-input {
        border: 1px solid #d8c8b8;
        border-radius: 8px;
        height: 44px;
        box-shadow: none;
    }

        .classic-input:focus {
            border-color: #8b5e34;
            box-shadow: 0 0 0 0.15rem rgba(139, 94, 52, 0.18);
        }

    .classic-update-btn {
        background: #b9852c;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 18px;
        font-weight: 600;
        transition: 0.2s ease;
    }

        .classic-update-btn:hover {
            background: #94691f;
            color: white;
            transform: translateY(-2px);
        }

    .classic-back-btn {
        background: #2f241d;
        color: white;
        border-radius: 8px;
        padding: 10px 18px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-left: 6px;
        transition: 0.2s ease;
    }

        .classic-back-btn:hover {
            background: #1f1813;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .text-danger {
        font-size: 14px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .classic-card-body {
            padding: 18px;
        }

        .classic-back-btn {
            margin-left: 0;
            margin-top: 8px;
        }
    }
</style>

<div class="container classic-page">

    <div class="classic-header">
        <h2>Edit User Profile</h2>
        @*<p>Update user information, role, and department from this admin panel.</p>*@
    </div>

    <div class="classic-card">

        <div class="classic-card-top">
            <h4>User Update Form</h4>
        </div>

        <div class="classic-card-body">

            @*<div class="classic-note">
                Only non-admin users can be edited from this page. Make sure role and department are selected correctly.
            </div>*@

            @using (Html.BeginForm("EditUser", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @Html.HiddenFor(model => model.UserId)

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="classic-form-group">
                    <label for="FullName">Full Name</label>
                    <input type="text"
                           id="FullName"
                           name="FullName"
                           class="form-control classic-input"
                           placeholder="Enter full name"
                           value="@Model.FullName" />

                    @Html.ValidationMessageFor(model => model.FullName, "", new { @class = "text-danger" })
                </div>

                <div class="classic-form-group">
                    <label for="RoleId">Role</label>
                    <select id="RoleId" name="RoleId" class="form-control classic-input">
                        <option value="">-- Select Role --</option>

                        @foreach (var role in ViewBag.Roles)
                        {
                            <option value="@role.RoleId" @(role.RoleId == Model.RoleId ? "selected" : "")>
                                @role.RoleName
                            </option>
                        }
                    </select>

                    @Html.ValidationMessageFor(model => model.RoleId, "", new { @class = "text-danger" })
                </div>

                <div class="classic-form-group">
                    <label for="DepartmentId">Department</label>
                    <select id="DepartmentId" name="DepartmentId" class="form-control classic-input">
                        <option value="">-- Select Department --</option>

                        @foreach (var department in ViewBag.Departments)
                        {
                            <option value="@department.DepartmentId" @(department.DepartmentId == Model.DepartmentId ? "selected" : "")>
                                @department.DepartmentName
                            </option>
                        }
                    </select>

                    @Html.ValidationMessageFor(model => model.DepartmentId, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="classic-update-btn">
                    Update User
                </button>

                <a href="@Url.Action("Users", "Admin")" class="classic-back-btn">
                    Back to Users
                </a>
            }

        </div>
    </div>

</div>