@using System.Linq
@model List<CorporateTaskManagementSystem.Entities.Models.User>

@{
    ViewBag.Title = "Manage Users";
}

<style>
    body {
        background: #f4f1ec;
    }

    .classic-page {
        padding: 30px 0;
    }

    .classic-header {
        background: #ffffff;
        border-left: 8px solid #8b5e34;
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 24px;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

        .classic-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
            color: #2f241d;
            margin: 0;
        }

        .classic-header p {
            color: #6b5b4f;
            margin: 6px 0 0;
            font-size: 15px;
        }

    .classic-create-btn {
        background: #2f5d8c;
        color: white;
        border-radius: 8px;
        padding: 10px 16px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s ease;
    }

        .classic-create-btn:hover {
            background: #254a70;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e3d7c8;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        overflow: hidden;
    }

    .classic-card-top {
        background: #3b2f2f;
        color: white;
        padding: 18px 24px;
        border-bottom: 4px solid #8b5e34;
    }

        .classic-card-top h4 {
            margin: 0;
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
        }

    .classic-card-body {
        padding: 24px;
    }

    .classic-note {
        background: #fbf7f1;
        border-left: 5px solid #b9852c;
        color: #5f4b3b;
        padding: 13px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .classic-filter-box {
        background: #fbf7f1;
        border: 1px solid #e3d7c8;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 22px;
    }

        .classic-filter-box label {
            font-weight: 700;
            color: #3b2f2f;
            margin-bottom: 6px;
        }

    .classic-input {
        border: 1px solid #d8c8b8;
        border-radius: 8px;
        height: 42px;
        box-shadow: none;
    }

        .classic-input:focus {
            border-color: #8b5e34;
            box-shadow: 0 0 0 0.15rem rgba(139, 94, 52, 0.18);
        }

    .classic-search-btn {
        background: #2b7a78;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-weight: 600;
        transition: 0.2s ease;
    }

        .classic-search-btn:hover {
            background: #22615f;
            color: white;
            transform: translateY(-2px);
        }

    .classic-reset-btn {
        background: #6b5b4f;
        color: white;
        border-radius: 8px;
        padding: 9px 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: 0.2s ease;
    }

        .classic-reset-btn:hover {
            background: #4f4037;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-table {
        margin-bottom: 0;
        border: 1px solid #e3d7c8;
    }

        .classic-table thead th {
            background: #2f241d;
            color: white;
            border-color: #4c3a2f;
            font-weight: 700;
            white-space: nowrap;
            vertical-align: middle;
        }

        .classic-table tbody td {
            vertical-align: middle;
            border-color: #eadfd1;
            color: #2f241d;
        }

        .classic-table tbody tr:nth-child(even) {
            background: #fbf7f1;
        }

        .classic-table tbody tr:hover {
            background: #f1e7db;
        }

    .classic-badge {
        border-radius: 30px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
        display: inline-block;
    }

    .badge-active {
        background: #e7f2ec;
        color: #2f7d59;
        border: 1px solid #b7dcc8;
    }

    .badge-inactive {
        background: #fff1f1;
        color: #9b2f2f;
        border: 1px solid #f0bcbc;
    }

    .classic-edit-btn {
        background: #2f5d8c;
        color: white;
        border-radius: 7px;
        padding: 7px 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 4px;
        transition: 0.2s ease;
    }

        .classic-edit-btn:hover {
            background: #254a70;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-warning-btn {
        background: #b9852c;
        color: white;
        border: none;
        border-radius: 7px;
        padding: 7px 12px;
        font-weight: 600;
        margin-bottom: 4px;
        transition: 0.2s ease;
    }

        .classic-warning-btn:hover {
            background: #94691f;
            color: white;
            transform: translateY(-2px);
        }

    .classic-success-btn {
        background: #2f7d59;
        color: white;
        border: none;
        border-radius: 7px;
        padding: 7px 12px;
        font-weight: 600;
        margin-bottom: 4px;
        transition: 0.2s ease;
    }

        .classic-success-btn:hover {
            background: #256345;
            color: white;
            transform: translateY(-2px);
        }

    .classic-back-btn {
        background: #2f241d;
        color: white;
        border-radius: 8px;
        padding: 10px 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-top: 22px;
        transition: 0.2s ease;
    }

        .classic-back-btn:hover {
            background: #1f1813;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-empty {
        padding: 28px;
        color: #6b5b4f;
        font-weight: 600;
        background: #fbf7f1;
    }

    .not-allowed-text {
        color: #8a7665;
        font-weight: 600;
    }

    .alert {
        border-radius: 10px;
    }

    @@media (max-width: 768px) {
        .classic-header {
            align-items: flex-start;
        }

            .classic-header h2 {
                font-size: 28px;
            }

        .classic-card-body {
            padding: 16px;
        }
    }
</style>

<div class="container classic-page">

    <div class="classic-header">
        <div>
            <h2>User Management Registry</h2>
            @*<p>Admin can search, filter, create, edit, activate, and deactivate system users.</p>*@
        </div>

        <a href="@Url.Action("CreateUser", "Admin")" class="classic-create-btn">
            Create New User
        </a>
    </div>

    <div class="classic-card">

        <div class="classic-card-top">
            <h4>Manage Users</h4>
        </div>

        <div class="classic-card-body">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }

            @*<div class="classic-note">
                Admin can view Leaders and Employees from here. Use search and department filter to find users quickly.
            </div>*@

            <div class="classic-filter-box">
                @using (Html.BeginForm("Users", "Admin", FormMethod.Get))
                {
                    <div class="row align-items-end">

                        <div class="col-md-5 mb-2">
                            <label>Search User</label>
                            <input type="text"
                                   name="searchText"
                                   value="@ViewBag.SearchText"
                                   class="form-control classic-input"
                                   placeholder="Search by name or email" />
                        </div>

                        <div class="col-md-4 mb-2">
                            <label>Filter by Department</label>
                            <select name="departmentId" class="form-control classic-input">
                                <option value="">All Departments</option>

                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.DepartmentId"
                                            @(ViewBag.DepartmentId != null && ViewBag.DepartmentId == dept.DepartmentId ? "selected" : "")>
                                        @dept.DepartmentName
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3 mb-2">
                            <button type="submit" class="classic-search-btn">
                                Search
                            </button>

                            <a href="@Url.Action("Users", "Admin")" class="classic-reset-btn">
                                Reset
                            </a>
                        </div>

                    </div>
                }
            </div>

            <div class="table-responsive">
                <table class="table classic-table">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Department</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@user.FullName</strong>
                                    </td>

                                    <td>@user.Email</td>

                                    <td>
                                        <strong>@user.Role.RoleName</strong>
                                    </td>

                                    <td>
                                        @(user.Department != null ? user.Department.DepartmentName : "N/A")
                                    </td>

                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="classic-badge badge-active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="classic-badge badge-inactive">Inactive</span>
                                        }
                                    </td>

                                    <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>

                                    <td>
                                        @if (user.Role.RoleName == "Admin")
                                        {
                                            <span class="not-allowed-text">Not allowed</span>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("EditUser", "Admin", new { id = user.UserId })"
                                               class="classic-edit-btn">
                                                Edit
                                            </a>

                                            if (user.IsActive)
                                            {
                                                using (Html.BeginForm("DeactivateUser", "Admin", new { id = user.UserId }, FormMethod.Post, new { onsubmit = "return confirm('Are you sure you want to deactivate this user?');", style = "display:inline;" }))
                                                {
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit" class="classic-warning-btn">
                                                        Deactivate
                                                    </button>
                                                }
                                            }
                                            else
                                            {
                                                using (Html.BeginForm("ActivateUser", "Admin", new { id = user.UserId }, FormMethod.Post, new { onsubmit = "return confirm('Are you sure you want to activate this user?');", style = "display:inline;" }))
                                                {
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit" class="classic-success-btn">
                                                        Activate
                                                    </button>
                                                }
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center classic-empty">
                                    No users found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <a href="@Url.Action("Index", "Admin")" class="classic-back-btn">
                Back to Dashboard
            </a>

        </div>
    </div>

</div>