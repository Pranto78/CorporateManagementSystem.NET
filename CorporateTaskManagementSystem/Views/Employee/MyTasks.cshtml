@using System.Linq
@using System.Collections.Generic
@model List<CorporateTaskManagementSystem.Entities.Models.TaskAssignment>

@{
    ViewBag.Title = "My Tasks";
    var remarksData = ViewBag.RemarksData as Dictionary<int, string>;
}

<style>
    body {
        background: #f4f1ec;
    }

    .classic-page {
        padding: 30px 0;
    }

    .classic-header {
        background: #ffffff;
        border-left: 8px solid #2b7a78;
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 24px;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

        .classic-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
            color: #2f241d;
            margin: 0;
        }

        .classic-header p {
            color: #6b5b4f;
            margin: 6px 0 0;
            font-size: 15px;
        }

    .classic-back-btn {
        background: #2f241d;
        color: white;
        border-radius: 8px;
        padding: 10px 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: 0.2s ease;
    }

        .classic-back-btn:hover {
            background: #1f1813;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e3d7c8;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        overflow: hidden;
    }

    .classic-card-top {
        background: #3b2f2f;
        color: white;
        padding: 18px 24px;
        border-bottom: 4px solid #2b7a78;
    }

        .classic-card-top h4 {
            margin: 0;
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
        }

    .classic-card-body {
        padding: 24px;
    }

    .classic-note {
        background: #fbf7f1;
        border-left: 5px solid #2b7a78;
        color: #5f4b3b;
        padding: 13px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .classic-table {
        margin-bottom: 0;
        border: 1px solid #e3d7c8;
    }

        .classic-table thead th {
            background: #2f241d;
            color: white;
            border-color: #4c3a2f;
            font-weight: 700;
            white-space: nowrap;
            vertical-align: middle;
        }

        .classic-table tbody td {
            vertical-align: middle;
            border-color: #eadfd1;
            color: #2f241d;
        }

        .classic-table tbody tr:nth-child(even) {
            background: #fbf7f1;
        }

        .classic-table tbody tr:hover {
            background: #f1e7db;
        }

    .classic-title {
        font-weight: 700;
        color: #2f241d;
    }

    .classic-description {
        max-width: 240px;
        color: #5f4b3b;
    }

    .classic-badge {
        border-radius: 30px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
        display: inline-block;
    }

    .badge-status {
        background: #e7f2f1;
        color: #2b7a78;
        border: 1px solid #b8ddda;
    }

    .badge-priority {
        background: #fff7e8;
        color: #b9852c;
        border: 1px solid #efd29d;
    }

    .badge-completed {
        background: #e7f2ec;
        color: #2f7d59;
        border: 1px solid #b7dcc8;
    }

    .classic-update-btn {
        background: #2f5d8c;
        color: white;
        border-radius: 7px;
        padding: 7px 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 5px;
        transition: 0.2s ease;
    }

        .classic-update-btn:hover {
            background: #254a70;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-history-btn {
        background: #6b5b4f;
        color: white;
        border-radius: 7px;
        padding: 7px 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 5px;
        transition: 0.2s ease;
    }

        .classic-history-btn:hover {
            background: #4f4037;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-empty {
        padding: 28px;
        color: #6b5b4f;
        font-weight: 600;
        background: #fbf7f1;
    }

    .remarks-text {
        color: #5f4b3b;
        font-weight: 500;
    }

    .no-remarks {
        color: #9a8a7a;
        font-style: italic;
    }

    .alert {
        border-radius: 10px;
    }

    @@media (max-width: 768px) {
        .classic-header {
            align-items: flex-start;
        }

            .classic-header h2 {
                font-size: 28px;
            }

        .classic-card-body {
            padding: 16px;
        }
    }
</style>

<div class="container classic-page">

    <div class="classic-header">
        <div>
            <h2>My Task Register</h2>
            @*<p>View assigned tasks, latest remarks, task status, and work history.</p>*@
        </div>

        <a href="@Url.Action("Index", "Employee")" class="classic-back-btn">
            Back to Dashboard
        </a>
    </div>

    <div class="classic-card">

        <div class="classic-card-top">
            <h4>Assigned Tasks</h4>
        </div>

        <div class="classic-card-body">

            @*<div class="classic-note">
                These tasks are assigned to you by your leader. You can update status until the task is completed.
            </div>*@

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            <div class="table-responsive">
                <table class="table classic-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Description</th>
                            <th>Assigned By</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Due Date</th>
                            <th>Assigned At</th>
                            <th>Latest Remarks</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="classic-title">@item.TaskItem.Title</span>
                                    </td>

                                    <td>
                                        <div class="classic-description">
                                            @item.TaskItem.Description
                                        </div>
                                    </td>

                                    <td>@item.AssignedByUser.FullName</td>

                                    <td>
                                        <span class="classic-badge badge-priority">
                                            @item.TaskItem.Priority
                                        </span>
                                    </td>

                                    <td>
                                        <span class="classic-badge badge-status">
                                            @item.TaskItem.Status
                                        </span>
                                    </td>

                                    <td>
                                        @(item.TaskItem.DueDate.HasValue
                                            ? item.TaskItem.DueDate.Value.ToString("dd MMM yyyy")
                                            : "No Due Date")
                                    </td>

                                    <td>
                                        @item.AssignedAt.ToString("dd MMM yyyy hh:mm tt")
                                    </td>

                                    <td>
                                        @if (remarksData != null && remarksData.ContainsKey(item.TaskItemId))
                                        {
                                            <span class="remarks-text">@remarksData[item.TaskItemId]</span>
                                        }
                                        else
                                        {
                                            <span class="no-remarks">No remarks</span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.TaskItem.Status != CorporateTaskManagementSystem.Common.Enums.TaskStatus.Completed)
                                        {
                                            <a href="@Url.Action("UpdateTaskStatus", "Employee", new { id = item.TaskAssignmentId })"
                                               class="classic-update-btn">
                                                Update Status
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="classic-badge badge-completed">
                                                Completed
                                            </span>
                                        }

                                        <a href="@Url.Action("TaskHistory", "Employee", new { id = item.TaskAssignmentId })"
                                           class="classic-history-btn">
                                            History
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center classic-empty">
                                    No tasks assigned yet.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>