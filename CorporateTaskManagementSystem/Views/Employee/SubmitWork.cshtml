@model List<CorporateTaskManagementSystem.Entities.Models.TaskAssignment>

@{
    ViewBag.Title = "Submit Work";
}

<style>
    body {
        background: #f4f1ec;
    }

    .classic-page {
        padding: 30px 0;
    }

    .classic-header {
        background: #ffffff;
        border-left: 8px solid #2b7a78;
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 24px;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

        .classic-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
            color: #2f241d;
            margin: 0;
        }

        .classic-header p {
            color: #6b5b4f;
            margin: 6px 0 0;
            font-size: 15px;
        }

    .classic-back-btn {
        background: #2f241d;
        color: white;
        border-radius: 8px;
        padding: 10px 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: 0.2s ease;
    }

        .classic-back-btn:hover {
            background: #1f1813;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e3d7c8;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        overflow: hidden;
    }

    .classic-card-top {
        background: #3b2f2f;
        color: white;
        padding: 18px 24px;
        border-bottom: 4px solid #2b7a78;
    }

        .classic-card-top h4 {
            margin: 0;
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
        }

    .classic-card-body {
        padding: 24px;
    }

    .classic-note {
        background: #fbf7f1;
        border-left: 5px solid #2b7a78;
        color: #5f4b3b;
        padding: 13px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .classic-table {
        margin-bottom: 0;
        border: 1px solid #e3d7c8;
    }

        .classic-table thead th {
            background: #2f241d;
            color: white;
            border-color: #4c3a2f;
            font-weight: 700;
            white-space: nowrap;
            vertical-align: middle;
        }

        .classic-table tbody td {
            vertical-align: middle;
            border-color: #eadfd1;
            color: #2f241d;
        }

        .classic-table tbody tr:nth-child(even) {
            background: #fbf7f1;
        }

        .classic-table tbody tr:hover {
            background: #f1e7db;
        }

    .task-title {
        font-weight: 700;
        color: #2f241d;
        font-size: 15px;
    }

    .task-description {
        color: #6b5b4f;
        font-size: 13px;
        display: block;
        margin-top: 4px;
        max-width: 260px;
    }

    .classic-badge {
        border-radius: 30px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
        display: inline-block;
    }

    .badge-status {
        background: #e7f2f1;
        color: #2b7a78;
        border: 1px solid #b8ddda;
    }

    .classic-input {
        border: 1px solid #d8c8b8;
        border-radius: 8px;
        box-shadow: none;
    }

        .classic-input:focus {
            border-color: #8b5e34;
            box-shadow: 0 0 0 0.15rem rgba(139, 94, 52, 0.18);
        }

    textarea.classic-input {
        resize: vertical;
        min-height: 70px;
    }

    .file-help-text {
        color: #8a7665;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }

    .classic-submit-btn {
        background: #2b7a78;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-weight: 600;
        transition: 0.2s ease;
    }

        .classic-submit-btn:hover {
            background: #22615f;
            color: white;
            transform: translateY(-2px);
        }

    .classic-empty {
        background: #fbf7f1;
        border-left: 5px solid #2b7a78;
        color: #5f4b3b;
        padding: 18px;
        border-radius: 10px;
        font-weight: 600;
    }

    .alert {
        border-radius: 10px;
    }

    @@media (max-width: 768px) {
        .classic-header {
            align-items: flex-start;
        }

            .classic-header h2 {
                font-size: 28px;
            }

        .classic-card-body {
            padding: 16px;
        }
    }
</style>

<div class="container classic-page">

    <div class="classic-header">
        <div>
            <h2>Work Submission Desk</h2>
            @*<p>Submit task progress, upload supporting files, and send remarks to your leader.</p>*@
        </div>

        <a href="@Url.Action("Index", "Employee")" class="classic-back-btn">
            Back to Dashboard
        </a>
    </div>

    <div class="classic-card">

        <div class="classic-card-top">
            <h4>Submit Work</h4>
        </div>

        <div class="classic-card-body">

            @*<div class="classic-note">
                Add a short remark and upload your work file before submitting. Allowed files: PDF, DOC, DOCX, JPG, PNG, and ZIP. Maximum size: 5 MB.
            </div>*@

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table classic-table">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Status</th>
                                <th>Due Date</th>
                                <th>Remarks</th>
                                <th>Upload File</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="task-title">@item.TaskItem.Title</span>
                                        <span class="task-description">@item.TaskItem.Description</span>
                                    </td>

                                    <td>
                                        <span class="classic-badge badge-status">
                                            @item.TaskItem.Status
                                        </span>
                                    </td>

                                    <td>
                                        @(item.TaskItem.DueDate.HasValue
                                            ? item.TaskItem.DueDate.Value.ToString("dd MMM yyyy")
                                            : "-")
                                    </td>

                                    @using (Html.BeginForm("SubmitWork", "Employee", FormMethod.Post, new { enctype = "multipart/form-data" }))
                                    {
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="taskAssignmentId" value="@item.TaskAssignmentId" />

                                        <td>
                                            <textarea name="remarks"
                                                      class="form-control classic-input"
                                                      rows="2"
                                                      placeholder="Write your remarks..."></textarea>
                                        </td>

                                        <td>
                                            <input type="file"
                                                   name="submissionFile"
                                                   class="form-control classic-input" />

                                            <span class="file-help-text">
                                                PDF, DOC, image or ZIP. Max 5 MB.
                                            </span>
                                        </td>

                                        <td>
                                            <button type="submit" class="classic-submit-btn">
                                                Submit
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="classic-empty">
                    No task available for submission.
                </div>
            }

        </div>
    </div>

</div>