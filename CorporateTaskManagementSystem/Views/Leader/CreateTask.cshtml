@model CorporateTaskManagementSystem.Web.ViewModels.TaskCreateViewModel

@{
    ViewBag.Title = "Create Task";
}

<style>
    body {
        background: #f4f1ec;
    }

    .classic-page {
        padding: 30px 0;
    }

    .classic-header {
        background: #ffffff;
        border-left: 8px solid #2f7d59;
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 24px;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
    }

        .classic-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
            color: #2f241d;
            margin: 0;
        }

        .classic-header p {
            color: #6b5b4f;
            margin: 6px 0 0;
            font-size: 15px;
        }

    .classic-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e3d7c8;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        overflow: hidden;
        max-width: 820px;
        margin: 0 auto;
    }

    .classic-card-top {
        background: #3b2f2f;
        color: white;
        padding: 18px 24px;
        border-bottom: 4px solid #2f7d59;
    }

        .classic-card-top h4 {
            margin: 0;
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
        }

    .classic-card-body {
        padding: 28px;
    }

    .classic-note {
        background: #fbf7f1;
        border-left: 5px solid #2f7d59;
        color: #5f4b3b;
        padding: 13px 16px;
        border-radius: 8px;
        margin-bottom: 22px;
        font-weight: 500;
    }

    .classic-form-group {
        margin-bottom: 20px;
    }

        .classic-form-group label {
            font-weight: 700;
            color: #3b2f2f;
            margin-bottom: 7px;
        }

    .classic-input {
        border: 1px solid #d8c8b8;
        border-radius: 8px;
        min-height: 44px;
        box-shadow: none;
    }

        .classic-input:focus {
            border-color: #8b5e34;
            box-shadow: 0 0 0 0.15rem rgba(139, 94, 52, 0.18);
        }

    textarea.classic-input {
        resize: vertical;
        min-height: 120px;
    }

    .classic-create-btn {
        background: #2f7d59;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 18px;
        font-weight: 600;
        transition: 0.2s ease;
    }

        .classic-create-btn:hover {
            background: #256345;
            color: white;
            transform: translateY(-2px);
        }

    .classic-back-btn {
        background: #2f241d;
        color: white;
        border-radius: 8px;
        padding: 10px 18px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-left: 6px;
        transition: 0.2s ease;
    }

        .classic-back-btn:hover {
            background: #1f1813;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .text-danger {
        font-size: 14px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .classic-card-body {
            padding: 18px;
        }

        .classic-header h2 {
            font-size: 28px;
        }

        .classic-back-btn {
            margin-left: 0;
            margin-top: 8px;
        }
    }
</style>

<div class="container classic-page">

    <div class="classic-header">
        <h2>Create New Task</h2>
        <p>Create a task, set priority and due date, then assign it to an employee.</p>
    </div>

    <div class="classic-card">

        <div class="classic-card-top">
            <h4>Task Creation Form</h4>
        </div>

        <div class="classic-card-body">

            <div class="classic-note">
                Fill in the task details carefully. After creation, the assigned employee will be able to view and update this task.
            </div>

            @using (Html.BeginForm("CreateTask", "Leader", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="classic-form-group">
                    <label for="Title">Task Title</label>
                    <input type="text"
                           id="Title"
                           name="Title"
                           class="form-control classic-input"
                           placeholder="Enter task title" />

                    @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                </div>

                <div class="classic-form-group">
                    <label for="Description">Description</label>
                    <textarea id="Description"
                              name="Description"
                              class="form-control classic-input"
                              rows="4"
                              placeholder="Enter task description"></textarea>

                    @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                </div>

                <div class="classic-form-group">
                    <label for="Priority">Priority</label>
                    <select id="Priority" name="Priority" class="form-control classic-input">
                        <option value="">-- Select Priority --</option>

                        @foreach (var priority in ViewBag.Priorities)
                        {
                            <option value="@((int)priority)">
                                @priority
                            </option>
                        }
                    </select>

                    @Html.ValidationMessageFor(model => model.Priority, "", new { @class = "text-danger" })
                </div>

                <div class="classic-form-group">
                    <label for="DueDate">Due Date</label>
                    <input type="date"
                           id="DueDate"
                           name="DueDate"
                           class="form-control classic-input" />

                    @Html.ValidationMessageFor(model => model.DueDate, "", new { @class = "text-danger" })
                </div>

                <div class="classic-form-group">
                    <label for="AssignedToUserId">Assign To Employee</label>
                    <select id="AssignedToUserId" name="AssignedToUserId" class="form-control classic-input">
                        <option value="">-- Select Employee --</option>

                        @foreach (var employee in ViewBag.Employees)
                        {
                            <option value="@employee.UserId">
                                @employee.FullName
                            </option>
                        }
                    </select>

                    @Html.ValidationMessageFor(model => model.AssignedToUserId, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="classic-create-btn">
                    Create Task
                </button>

                <a href="@Url.Action("Index", "Leader")" class="classic-back-btn">
                    Back to Dashboard
                </a>
            }

        </div>
    </div>

</div>