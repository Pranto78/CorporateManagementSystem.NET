@using System.Linq
@model List<CorporateTaskManagementSystem.Entities.Models.TaskStatusHistory>

@{
    ViewBag.Title = "Task History";
}

<style>
    body {
        background: #f4f1ec;
    }

    .classic-page {
        padding: 30px 0;
    }

    .classic-header {
        background: #ffffff;
        border-left: 8px solid #2f7d59;
        border-radius: 12px;
        padding: 26px 30px;
        margin-bottom: 24px;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

        .classic-header h2 {
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
            color: #2f241d;
            margin: 0;
        }

        .classic-header p {
            color: #6b5b4f;
            margin: 6px 0 0;
            font-size: 15px;
        }

    .classic-back-btn {
        background: #2f241d;
        color: white;
        border-radius: 8px;
        padding: 10px 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: 0.2s ease;
    }

        .classic-back-btn:hover {
            background: #1f1813;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

    .classic-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e3d7c8;
        box-shadow: 0 10px 25px rgba(80, 60, 40, 0.12);
        overflow: hidden;
    }

    .classic-card-top {
        background: #3b2f2f;
        color: white;
        padding: 18px 24px;
        border-bottom: 4px solid #2f7d59;
    }

        .classic-card-top h4 {
            margin: 0;
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
        }

    .classic-card-body {
        padding: 24px;
    }

    .task-info-box {
        background: #fbf7f1;
        border-left: 5px solid #2f7d59;
        color: #5f4b3b;
        padding: 15px 18px;
        border-radius: 8px;
        margin-bottom: 22px;
    }

        .task-info-box h5 {
            font-family: Georgia, 'Times New Roman', serif;
            font-weight: 700;
            color: #2f241d;
            margin-bottom: 6px;
        }

        .task-info-box p {
            margin-bottom: 0;
            color: #6b5b4f;
            font-weight: 500;
        }

    .assigned-name {
        color: #2f7d59;
        font-weight: 700;
    }

    .classic-table {
        margin-bottom: 0;
        border: 1px solid #e3d7c8;
    }

        .classic-table thead th {
            background: #2f241d;
            color: white;
            border-color: #4c3a2f;
            font-weight: 700;
            white-space: nowrap;
            vertical-align: middle;
        }

        .classic-table tbody td {
            vertical-align: middle;
            border-color: #eadfd1;
            color: #2f241d;
        }

        .classic-table tbody tr:nth-child(even) {
            background: #fbf7f1;
        }

        .classic-table tbody tr:hover {
            background: #f1e7db;
        }

    .changed-by {
        font-weight: 700;
        color: #2f241d;
    }

    .classic-badge {
        border-radius: 30px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
        display: inline-block;
    }

    .badge-old {
        background: #fff7e8;
        color: #b9852c;
        border: 1px solid #efd29d;
    }

    .badge-new {
        background: #e7f2f1;
        color: #2f7d59;
        border: 1px solid #b7dcc8;
    }

    .remarks-text {
        color: #5f4b3b;
        font-weight: 500;
    }

    .no-remarks {
        color: #9a8a7a;
        font-style: italic;
    }

    .history-time {
        color: #6b5b4f;
        font-weight: 600;
        white-space: nowrap;
    }

    .classic-empty {
        padding: 28px;
        color: #6b5b4f;
        font-weight: 600;
        background: #fbf7f1;
    }

    @@media (max-width: 768px) {
        .classic-header {
            align-items: flex-start;
        }

            .classic-header h2 {
                font-size: 28px;
            }

        .classic-card-body {
            padding: 16px;
        }
    }
</style>

<div class="container classic-page">

    <div class="classic-header">
        @*<div>
            <h2>Leader Task History</h2>
            <p>View the complete status timeline, remarks, and progress history of this assigned task.</p>
        </div>*@

        <a href="@Url.Action("AssignedTasks", "Leader")" class="classic-back-btn">
            Back to Assigned Tasks
        </a>
    </div>

    <div class="classic-card">

        <div class="classic-card-top">
            <h4>Status Change Record</h4>
        </div>

        <div class="classic-card-body">

            <div class="task-info-box">
                <h5>Task: @ViewBag.TaskTitle</h5>
                <p>
                    Assigned To:
                    <span class="assigned-name">@ViewBag.AssignedTo</span>
                </p>
            </div>

            <div class="table-responsive">
                <table class="table classic-table">
                    <thead>
                        <tr>
                            <th>Changed By</th>
                            <th>Old Status</th>
                            <th>New Status</th>
                            <th>Remarks</th>
                            <th>Changed At</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="changed-by">@item.ChangedByUser.FullName</span>
                                    </td>

                                    <td>
                                        <span class="classic-badge badge-old">
                                            @item.OldStatus
                                        </span>
                                    </td>

                                    <td>
                                        <span class="classic-badge badge-new">
                                            @item.NewStatus
                                        </span>
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Remarks))
                                        {
                                            <span class="remarks-text">@item.Remarks</span>
                                        }
                                        else
                                        {
                                            <span class="no-remarks">No remarks</span>
                                        }
                                    </td>

                                    <td>
                                        <span class="history-time">
                                            @item.ChangedAt.ToString("dd MMM yyyy hh:mm tt")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center classic-empty">
                                    No history found for this task.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>